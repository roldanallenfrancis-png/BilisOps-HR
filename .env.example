# Copy to .env and fill in from: Supabase Dashboard → Project Settings → API.
# These are shared by ALL builds (landing, app, admin, kiosk APK) so every
# domain talks to the same database. Without them, the app falls back to a
# local in-browser stub (dev only — no cross-device sync).
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
